struct vertex_in {
    pos: float3;
    uv: float2;
}

struct vertex_out {
    pos: float4;
    uv: float2;
}

#[set(mvp)]
const constants: {
    mvp: float4x4;
};

#[set(textures)]
const tex: tex2d;

#[set(textures)]
const sam: sampler;

#[vertex]
fun pos(input: vertex_in): vertex_out {
    var output: vertex_out;
    output.pos = constants.mvp * float4(input.pos, 1.0);
    output.uv = input.uv;
    return output;
}

#[fragment]
fun pix(input: vertex_out): float4 {
    var color: float4 = sample(tex, sam, input.uv);
    return color;
}

#[pipe]
struct pipeline {
    vertex = pos;
    fragment = pix;
    depth_stencil_format = TEXTURE_FORMAT_DEPTH32_FLOAT;
    depth_write = true;
    depth_compare = COMPARE_LESS;
    format = framebuffer_format();
}
