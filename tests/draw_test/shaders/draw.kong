struct vertex_in {
    pos: float3;
    uv: float2;
}

struct vertex_out {
    pos: float4;
    uv: float2;
}

#[set(everything)]
const constants: {
    mvp: float4x4;
    color: float4;
};

#[set(everything)]
const tex: tex2d;

#[set(everything)]
const sam: sampler;

#[vertex]
fun pos_shader(input: vertex_in): vertex_out {
    var out: vertex_out;
    
    var position: float4;
    position.xyz = input.pos;
    position.w = 1.0;
    
    out.pos = constants.mvp * position;
    out.uv = input.uv;
    
    return out;
}

#[fragment]
fun pix(input: vertex_out): float4 {
    // 测试：纯蓝色，不使用纹理
    return float4(0.0, 0.0, 1.0, 1.0);
}

#[pipe]
struct text_pipeline {
    vertex = pos_shader;
    fragment = pix;
    format = framebuffer_format();
    depth_format = TEXTURE_FORMAT_DEPTH32_FLOAT;
    depth_write = false;
    depth_compare = COMPARE_ALWAYS;
    blend_source = BLEND_FACTOR_ONE;
    blend_destination = BLEND_FACTOR_ONE_MINUS_SRC_ALPHA;
    blend_operation = BLEND_OPERATION_ADD;
    alpha_blend_source = BLEND_FACTOR_ONE;
    alpha_blend_destination = BLEND_FACTOR_ONE_MINUS_SRC_ALPHA;
    alpha_blend_operation = BLEND_OPERATION_ADD;
}
