struct vertex_in {
    pos: float2;
}

struct vertex_out {
    pos: float4;
    tex_coord: float2;
}

#[set(everything)]
const tex: tex2d;

#[set(everything)]
const sam: sampler;

fun pos(input: vertex_in): vertex_out {
    var out: vertex_out;
    var madd: float2 = float2(0.5, 0.5);
    out.tex_coord = input.pos.xy * madd + madd;
    out.pos = float4(input.pos.x, input.pos.y, 0.0, 1.0);
    return out;
}

fun pix(input: vertex_out): float4 {
    var lod: float = floor(input.tex_coord.x * 4.0);
    return sample_lod(tex, sam, input.tex_coord, lod);
}

#[pipe]
struct pipeline {
    vertex = pos;
    fragment = pix;
    format = framebuffer_format();
}
