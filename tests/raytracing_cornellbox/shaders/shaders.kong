struct vertex_in {
	pos: float3;
	tex: float2;
}

struct vertex_out {
	pos: float4;
	tex: float2;
}

#[set(everything)]
const constants: {
	mvp: float4x4;
};

#[set(everything), set(compute)]
const render_target: tex2d<TEXTURE_FORMAT_RGBA32_FLOAT>;

#[set(everything)]
const render_target_sampler: sampler;

fun pix(input: vertex_out): float4 {
	var c: float4 = sample(render_target, render_target_sampler, input.tex);
	return float4(c.r, c.g, c.b, 1.0);
}

fun pos(input: vertex_in): vertex_out {
	var o: vertex_out;
	o.pos = float4(input.pos.xy, 0.5, 1.0);
	o.tex = input.tex;
	return o;
}

#[pipe]
struct pipeline {
	vertex = pos;
	fragment = pix;
	format = framebuffer_format();
}

#[set(compute)]
const rc: {
	camera: float4;
	light: float4;
	sky_top: float4;
	sky_bottom: float4;
};

#[set(compute), storage]
const vertex_buffer: {
	v0: float3;
	padding: float;
};

#[set(compute), storage]
const index_buffer: {
	count: uint;
	padding: uint;
};

fun ray_triangle_intersect(ray_origin: float3, ray_dir: float3, v0: float3, v1: float3, v2: float3): float {
	var EPSILON: float = 0.0000001;
	
	var edge1: float3 = v1 - v0;
	var edge2: float3 = v2 - v0;
	var h: float3 = cross(ray_dir, edge2);
	var a: float = dot(edge1, h);
	
	if (a > -EPSILON && a < EPSILON) {
		return -1.0;
	}
	
	var f: float = 1.0 / a;
	var s: float3 = ray_origin - v0;
	var u: float = f * dot(s, h);
	
	if (u < 0.0 || u > 1.0) {
		return -1.0;
	}
	
	var q: float3 = cross(s, edge1);
	var v: float = f * dot(ray_dir, q);
	
	if (v < 0.0 || u + v > 1.0) {
		return -1.0;
	}
	
	var t: float = f * dot(edge2, q);
	
	if (t > EPSILON) {
		return t;
	}
	
	return -1.0;
}

#[compute, threads(16, 16, 1)]
fun comp(): void {
	var idx: uint2 = dispatch_thread_id().xy;
	var screen_x: float = float(idx.x);
	var screen_y: float = float(idx.y);
	
	var aspect: float = 800.0 / 600.0;
	var fov: float = 1.0;
	
	var ray_x: float = (2.0 * screen_x / 800.0 - 1.0) * aspect * fov;
	var ray_y: float = (1.0 - 2.0 * screen_y / 600.0) * fov;
	
	var ray_origin: float3 = rc.camera.xyz;
	var yaw: float = rc.camera.w;
	var pitch: float = rc.light.w;
	
	var cos_yaw: float = cos(yaw);
	var sin_yaw: float = sin(yaw);
	var cos_pitch: float = cos(pitch);
	var sin_pitch: float = sin(pitch);
	
	var forward_x: float = sin_yaw * cos_pitch;
	var forward_y: float = sin_pitch;
	var forward_z: float = cos_yaw * cos_pitch;
	
	var right_x: float = cos_yaw;
	var right_y: float = 0.0;
	var right_z: float = -sin_yaw;	
	var up_x: float = -sin_yaw * sin_pitch;
	var up_y: float = cos_pitch;
	var up_z: float = -cos_yaw * sin_pitch;
	
	var ray_dir: float3 = normalize(float3(
		forward_x + ray_x * right_x + ray_y * up_x,
		forward_y + ray_y * up_y,
		forward_z + ray_x * right_z + ray_y * up_z
	));
	
	var closest_t: float = 100000.0;
	var instance: float = 0.0;
	
	var t: float = -1.0;
	
	var tall_v0: float3 = float3(-1.8, -2.5, -0.8);
	var tall_v1: float3 = float3(-0.8, -2.5, -0.8);
	var tall_v2: float3 = float3(-0.8, -0.8, -0.8);
	var tall_v3: float3 = float3(-1.8, -0.8, -0.8);
	var tall_v4: float3 = float3(-1.8, -2.5, 0.2);
	var tall_v5: float3 = float3(-0.8, -2.5, 0.2);
	var tall_v6: float3 = float3(-0.8, -0.8, 0.2);
	var tall_v7: float3 = float3(-1.8, -0.8, 0.2);
	
	t = ray_triangle_intersect(ray_origin, ray_dir, tall_v0, tall_v1, tall_v2);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 1.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, tall_v0, tall_v2, tall_v3);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 1.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, tall_v4, tall_v6, tall_v5);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 1.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, tall_v4, tall_v7, tall_v6);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 1.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, tall_v0, tall_v4, tall_v5);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 1.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, tall_v0, tall_v5, tall_v1);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 1.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, tall_v1, tall_v5, tall_v6);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 1.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, tall_v1, tall_v6, tall_v2);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 1.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, tall_v2, tall_v6, tall_v7);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 1.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, tall_v2, tall_v7, tall_v3);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 1.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, tall_v3, tall_v7, tall_v4);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 1.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, tall_v3, tall_v4, tall_v0);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 1.0; }
	
	var short_v0: float3 = float3(0.5, -2.5, -1.5);
	var short_v1: float3 = float3(1.5, -2.5, -1.5);
	var short_v2: float3 = float3(1.5, -1.8, -1.5);
	var short_v3: float3 = float3(0.5, -1.8, -1.5);
	var short_v4: float3 = float3(0.5, -2.5, -0.5);
	var short_v5: float3 = float3(1.5, -2.5, -0.5);
	var short_v6: float3 = float3(1.5, -1.8, -0.5);
	var short_v7: float3 = float3(0.5, -1.8, -0.5);
	
	t = ray_triangle_intersect(ray_origin, ray_dir, short_v0, short_v1, short_v2);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 2.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, short_v0, short_v2, short_v3);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 2.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, short_v4, short_v6, short_v5);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 2.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, short_v4, short_v7, short_v6);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 2.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, short_v0, short_v4, short_v5);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 2.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, short_v0, short_v5, short_v1);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 2.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, short_v1, short_v5, short_v6);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 2.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, short_v1, short_v6, short_v2);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 2.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, short_v2, short_v6, short_v7);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 2.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, short_v2, short_v7, short_v3);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 2.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, short_v3, short_v7, short_v4);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 2.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, short_v3, short_v4, short_v0);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 2.0; }
	
	var wall_thick: float = 0.3;
	
	var left_v0: float3 = float3(-2.5 - wall_thick, -2.5, -2.5);
	var left_v1: float3 = float3(-2.5 - wall_thick, 2.5, -2.5);
	var left_v2: float3 = float3(-2.5 - wall_thick, 2.5, 2.5);
	var left_v3: float3 = float3(-2.5 - wall_thick, -2.5, 2.5);
	
	t = ray_triangle_intersect(ray_origin, ray_dir, left_v0, left_v1, left_v2);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 3.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, left_v0, left_v2, left_v3);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 3.0; }
	
	var right_v0: float3 = float3(2.5, -2.5, -2.5);
	var right_v1: float3 = float3(2.5, 2.5, -2.5);
	var right_v2: float3 = float3(2.5, 2.5, 2.5);
	var right_v3: float3 = float3(2.5, -2.5, 2.5);
	
	t = ray_triangle_intersect(ray_origin, ray_dir, right_v0, right_v1, right_v2);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 4.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, right_v0, right_v2, right_v3);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 4.0; }
	
	var floor_v0: float3 = float3(-2.5, -2.5 - wall_thick, -2.5);
	var floor_v1: float3 = float3(2.5, -2.5 - wall_thick, -2.5);
	var floor_v2: float3 = float3(2.5, -2.5 - wall_thick, 2.5);
	var floor_v3: float3 = float3(-2.5, -2.5 - wall_thick, 2.5);
	
	t = ray_triangle_intersect(ray_origin, ray_dir, floor_v0, floor_v1, floor_v2);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 5.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, floor_v0, floor_v2, floor_v3);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 5.0; }
	
	var ceil_v0: float3 = float3(-2.5, 2.5 + wall_thick, -2.5);
	var ceil_v1: float3 = float3(2.5, 2.5 + wall_thick, -2.5);
	var ceil_v2: float3 = float3(2.5, 2.5 + wall_thick, 2.5);
	var ceil_v3: float3 = float3(-2.5, 2.5 + wall_thick, 2.5);
	
	t = ray_triangle_intersect(ray_origin, ray_dir, ceil_v0, ceil_v1, ceil_v2);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 6.0; }
	t = ray_triangle_intersect(ray_origin, ray_dir, ceil_v0, ceil_v2, ceil_v3);
	if (t > 0.0 && t < closest_t) { closest_t = t; instance = 6.0; }
	
	var color: float3;
	
	if (instance < 0.5) {
		var slope: float = ray_dir.y;
		var t: float = saturate(slope * 5.0 + 0.5);
		color = lerp(rc.sky_bottom.xyz, rc.sky_top.xyz, t);
	}
	
	if (instance > 0.5 && instance < 1.5) {
		color = float3(0.9, 0.9, 0.9);
	}
	
	if (instance > 1.5 && instance < 2.5) {
		color = float3(0.9, 0.9, 0.9);
	}
	
	if (instance > 2.5 && instance < 3.5) {
		color = float3(0.9, 0.1, 0.1);
	}
	
	if (instance > 3.5 && instance < 4.5) {
		color = float3(0.1, 0.9, 0.1);
	}
	
	if (instance > 4.5 && instance < 5.5) {
		color = float3(0.5, 0.5, 0.5);
	}
	
	if (instance > 5.5) {
		color = float3(0.9, 0.9, 0.9);
	}
	
	render_target[idx] = float4(color, 1.0);
}
