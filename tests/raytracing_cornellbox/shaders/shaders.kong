struct vertex_in {
	pos: float3;
	tex: float2;
}

struct vertex_out {
	pos: float4;
	tex: float2;
}

#[set(everything)]
const constants: {
	mvp: float4x4;
};

#[set(everything), set(compute)]
const render_target: tex2d<TEXTURE_FORMAT_RGBA32_FLOAT>;

#[set(everything)]
const render_target_sampler: sampler;

fun pix(input: vertex_out): float4 {
	var c: float4 = sample(render_target, render_target_sampler, input.tex);
	return float4(c.r, c.g, c.b, 1.0);
}

fun pos(input: vertex_in): vertex_out {
	var o: vertex_out;
	o.pos = float4(input.pos.xy, 0.5, 1.0);
	o.tex = input.tex;
	return o;
}

#[pipe]
struct pipeline {
	vertex = pos;
	fragment = pix;
	format = framebuffer_format();
}

#[set(compute)]
const rc: {
	camera: float4;
	light: float4;
	sky_top: float4;
	sky_bottom: float4;
};

#[set(compute), storage]
const vertex_buffer: {
	v0: float3;
	padding: float;
};

#[set(compute), storage]
const index_buffer: {
	count: uint;
	padding: uint;
};

#[compute, threads(16, 16, 1)]
fun comp(): void {
	var idx: uint2 = dispatch_thread_id().xy;
	var screen_x: float = float(idx.x);
	var screen_y: float = float(idx.y);
	
	var aspect: float = 800.0 / 600.0;
	var fov: float = 1.0;
	
	var ray_x: float = (2.0 * screen_x / 800.0 - 1.0) * aspect * fov;
	var ray_y: float = (1.0 - 2.0 * screen_y / 600.0) * fov;
	
	var ray_origin: float3 = rc.camera.xyz;
	var yaw: float = rc.camera.w;
	var pitch: float = rc.light.w;
	
	var cos_yaw: float = cos(yaw);
	var sin_yaw: float = sin(yaw);
	var cos_pitch: float = cos(pitch);
	var sin_pitch: float = sin(pitch);
	
	var forward_x: float = sin_yaw * cos_pitch;
	var forward_y: float = sin_pitch;
	var forward_z: float = cos_yaw * cos_pitch;
	
	var right_x: float = cos_yaw;
	var right_y: float = 0.0;
	var right_z: float = -sin_yaw;	
	var up_x: float = -sin_yaw * sin_pitch;
	var up_y: float = cos_pitch;
	var up_z: float = -cos_yaw * sin_pitch;
	
	var ray_dir: float3 = normalize(float3(
		forward_x + ray_x * right_x + ray_y * up_x,
		forward_y + ray_y * up_y,
		forward_z + ray_x * right_z + ray_y * up_z
	));
	
	var closest_t: float = 100000.0;
	var instance: float = 0.0;
	
	var inv_x: float = 1.0 / ray_dir.x;
	var inv_y: float = 1.0 / ray_dir.y;
	var inv_z: float = 1.0 / ray_dir.z;
	
	var tall_min_x: float = -1.8;
	var tall_max_x: float = -0.8;
	var tall_min_y: float = -2.5;
	var tall_max_y: float = -0.8;
	var tall_min_z: float = -0.8;
	var tall_max_z: float = 0.2;
	
	var t1x_tall: float = (tall_min_x - ray_origin.x) * inv_x;
	var t2x_tall: float = (tall_max_x - ray_origin.x) * inv_x;
	var t1y_tall: float = (tall_min_y - ray_origin.y) * inv_y;
	var t2y_tall: float = (tall_max_y - ray_origin.y) * inv_y;
	var t1z_tall: float = (tall_min_z - ray_origin.z) * inv_z;
	var t2z_tall: float = (tall_max_z - ray_origin.z) * inv_z;
	
	var tmin_tall: float = max(max(min(t1x_tall, t2x_tall), min(t1y_tall, t2y_tall)), min(t1z_tall, t2z_tall));
	var tmax_tall: float = min(min(max(t1x_tall, t2x_tall), max(t1y_tall, t2y_tall)), max(t1z_tall, t2z_tall));
	
	var tall_hit: bool = tmax_tall >= tmin_tall && tmax_tall > 0.0;
	var tall_t: float = tmin_tall;
	if (tall_hit && tmin_tall < 0.001) {
		tall_t = tmax_tall;
	}
	
	var short_min_x: float = 0.5;
	var short_max_x: float = 1.5;
	var short_min_y: float = -2.5;
	var short_max_y: float = -1.8;
	var short_min_z: float = -1.5;
	var short_max_z: float = -0.5;
	
	var t1x_short: float = (short_min_x - ray_origin.x) * inv_x;
	var t2x_short: float = (short_max_x - ray_origin.x) * inv_x;
	var t1y_short: float = (short_min_y - ray_origin.y) * inv_y;
	var t2y_short: float = (short_max_y - ray_origin.y) * inv_y;
	var t1z_short: float = (short_min_z - ray_origin.z) * inv_z;
	var t2z_short: float = (short_max_z - ray_origin.z) * inv_z;
	
	var tmin_short: float = max(max(min(t1x_short, t2x_short), min(t1y_short, t2y_short)), min(t1z_short, t2z_short));
	var tmax_short: float = min(min(max(t1x_short, t2x_short), max(t1y_short, t2y_short)), max(t1z_short, t2z_short));
	
	var short_hit: bool = tmax_short >= tmin_short && tmax_short > 0.0;
	var short_t: float = tmin_short;
	if (short_hit && tmin_short < 0.001) {
		short_t = tmax_short;
	}
	
	if (tall_hit && tall_t < closest_t) {
		closest_t = tall_t;
		instance = 1.0;
	}
	
	if (short_hit && short_t < closest_t) {
		closest_t = short_t;
		instance = 2.0;
	}
	
	var wall_thick: float = 0.3;
	
	var left_min_x: float = -2.5 - wall_thick;
	var left_max_x: float = -2.5;
	var left_min_y: float = -2.5;
	var left_max_y: float = 2.5;
	var left_min_z: float = -2.5;
	var left_max_z: float = 2.5;
	
	var t1x_left: float = (left_min_x - ray_origin.x) * inv_x;
	var t2x_left: float = (left_max_x - ray_origin.x) * inv_x;
	var t1y_left: float = (left_min_y - ray_origin.y) * inv_y;
	var t2y_left: float = (left_max_y - ray_origin.y) * inv_y;
	var t1z_left: float = (left_min_z - ray_origin.z) * inv_z;
	var t2z_left: float = (left_max_z - ray_origin.z) * inv_z;
	
	var tmin_left: float = max(max(min(t1x_left, t2x_left), min(t1y_left, t2y_left)), min(t1z_left, t2z_left));
	var tmax_left: float = min(min(max(t1x_left, t2x_left), max(t1y_left, t2y_left)), max(t1z_left, t2z_left));
	
	var left_hit: bool = tmax_left >= tmin_left && tmax_left > 0.0;
	var left_t: float = tmin_left;
	if (left_hit && tmin_left < 0.001) {
		left_t = tmax_left;
	}
	
	var right_min_x: float = 2.5;
	var right_max_x: float = 2.5 + wall_thick;
	var right_min_y: float = -2.5;
	var right_max_y: float = 2.5;
	var right_min_z: float = -2.5;
	var right_max_z: float = 2.5;
	
	var t1x_right: float = (right_min_x - ray_origin.x) * inv_x;
	var t2x_right: float = (right_max_x - ray_origin.x) * inv_x;
	var t1y_right: float = (right_min_y - ray_origin.y) * inv_y;
	var t2y_right: float = (right_max_y - ray_origin.y) * inv_y;
	var t1z_right: float = (right_min_z - ray_origin.z) * inv_z;
	var t2z_right: float = (right_max_z - ray_origin.z) * inv_z;
	
	var tmin_right: float = max(max(min(t1x_right, t2x_right), min(t1y_right, t2y_right)), min(t1z_right, t2z_right));
	var tmax_right: float = min(min(max(t1x_right, t2x_right), max(t1y_right, t2y_right)), max(t1z_right, t2z_right));
	
	var right_hit: bool = tmax_right >= tmin_right && tmax_right > 0.0;
	var right_t: float = tmin_right;
	if (right_hit && tmin_right < 0.001) {
		right_t = tmax_right;
	}
	
	var floor_min_x: float = -2.5;
	var floor_max_x: float = 2.5;
	var floor_min_y: float = -2.5 - wall_thick;
	var floor_max_y: float = -2.5;
	var floor_min_z: float = -2.5;
	var floor_max_z: float = 2.5;
	
	var t1x_floor: float = (floor_min_x - ray_origin.x) * inv_x;
	var t2x_floor: float = (floor_max_x - ray_origin.x) * inv_x;
	var t1y_floor: float = (floor_min_y - ray_origin.y) * inv_y;
	var t2y_floor: float = (floor_max_y - ray_origin.y) * inv_y;
	var t1z_floor: float = (floor_min_z - ray_origin.z) * inv_z;
	var t2z_floor: float = (floor_max_z - ray_origin.z) * inv_z;
	
	var tmin_floor: float = max(max(min(t1x_floor, t2x_floor), min(t1y_floor, t2y_floor)), min(t1z_floor, t2z_floor));
	var tmax_floor: float = min(min(max(t1x_floor, t2x_floor), max(t1y_floor, t2y_floor)), max(t1z_floor, t2z_floor));
	
	var floor_hit: bool = tmax_floor >= tmin_floor && tmax_floor > 0.0;
	var floor_t: float = tmin_floor;
	if (floor_hit && tmin_floor < 0.001) {
		floor_t = tmax_floor;
	}
	
	var ceil_min_x: float = -2.5;
	var ceil_max_x: float = 2.5;
	var ceil_min_y: float = 2.5;
	var ceil_max_y: float = 2.5 + wall_thick;
	var ceil_min_z: float = -2.5;
	var ceil_max_z: float = 2.5;
	
	var t1x_ceil: float = (ceil_min_x - ray_origin.x) * inv_x;
	var t2x_ceil: float = (ceil_max_x - ray_origin.x) * inv_x;
	var t1y_ceil: float = (ceil_min_y - ray_origin.y) * inv_y;
	var t2y_ceil: float = (ceil_max_y - ray_origin.y) * inv_y;
	var t1z_ceil: float = (ceil_min_z - ray_origin.z) * inv_z;
	var t2z_ceil: float = (ceil_max_z - ray_origin.z) * inv_z;
	
	var tmin_ceil: float = max(max(min(t1x_ceil, t2x_ceil), min(t1y_ceil, t2y_ceil)), min(t1z_ceil, t2z_ceil));
	var tmax_ceil: float = min(min(max(t1x_ceil, t2x_ceil), max(t1y_ceil, t2y_ceil)), max(t1z_ceil, t2z_ceil));
	
	var ceil_hit: bool = tmax_ceil >= tmin_ceil && tmax_ceil > 0.0;
	var ceil_t: float = tmin_ceil;
	if (ceil_hit && tmin_ceil < 0.001) {
		ceil_t = tmax_ceil;
	}
	
	if (left_hit && left_t < closest_t) {
		closest_t = left_t;
		instance = 3.0;
	}
	
	if (right_hit && right_t < closest_t) {
		closest_t = right_t;
		instance = 4.0;
	}
	
	if (floor_hit && floor_t < closest_t) {
		closest_t = floor_t;
		instance = 5.0;
	}
	
	if (ceil_hit && ceil_t < closest_t) {
		closest_t = ceil_t;
		instance = 6.0;
	}
	
	var color: float3;
	
	if (instance < 0.5) {
		var slope: float = ray_dir.y;
		var t: float = saturate(slope * 5.0 + 0.5);
		color = lerp(rc.sky_bottom.xyz, rc.sky_top.xyz, t);
	}
	
	if (instance > 0.5 && instance < 1.5) {
		color = float3(0.9, 0.9, 0.9);
	}
	
	if (instance > 1.5 && instance < 2.5) {
		color = float3(0.9, 0.9, 0.9);
	}
	
	if (instance > 2.5 && instance < 3.5) {
		color = float3(0.9, 0.1, 0.1);
	}
	
	if (instance > 3.5 && instance < 4.5) {
		color = float3(0.1, 0.9, 0.1);
	}
	
	if (instance > 4.5 && instance < 5.5) {
		color = float3(0.5, 0.5, 0.5);
	}
	
	if (instance > 5.5) {
		color = float3(0.9, 0.9, 0.9);
	}
	
	render_target[idx] = float4(color, 1.0);
}
