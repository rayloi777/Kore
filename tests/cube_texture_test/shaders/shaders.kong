struct vertex_in {
    pos: float3;
    tex: float3;
}

struct vertex_out {
    pos: float4;
    tex: float3;
}

#[set(everything), indexed]
const constants: {
    mvp: float4x4;
};

fun pos(input: vertex_in): vertex_out {
    var out: vertex_out;
    
    out.pos = constants.mvp * float4(input.pos, 1.0);
    out.tex = input.tex;

    return out;
}

#[set(everything)]
const tex: tex2d;

#[set(everything)]
const sam: sampler;

fun pix(input: vertex_out): float4 {
    var color: float4 = sample(tex, sam, input.tex.xy);
    return float4(color.r, color.g, color.b, 1.0);
}

#[pipe]
struct pipeline {
    vertex = pos;
    fragment = pix;
    format = framebuffer_format();
}
